<?xml version="1.0" encoding="UTF-8"?>
<definition>
  <title>Mereaks Secrets_MODIFY DT_ItemRecipes</title>
  <author>Moria MOD Creator</author>
  <description>20 modifications to DT_ItemRecipes.json</description>
  <mod file="Moria\Content\Tech\Data\Items\DT_ItemRecipes.json">
    <change item="Dain_Battleaxe" property="DefaultRequiredMaterials[0].MaterialHandle.RowName" value="Item.KhazadSteelIngot" />
    <change item="Dain_Battleaxe" property="DefaultUnlocks.UnlockRequiredItems.UnlockRequiredItems.RowName" value="Item.KhazadSteelIngot" />
    <change item="Dain_Warhammer" property="DefaultRequiredMaterials[0].MaterialHandle.RowName" value="Item.KhazadSteelIngot" />
    <change item="Dain_Warhammer" property="DefaultRequiredMaterials[1].MaterialHandle.RowName" value="Item.SilverIngot" />
    <change item="Dain_Warhammer" property="DefaultUnlocks.UnlockRequiredConstructions.UnlockRequiredConstructions.RowName" value="CraftingStation_AdvancedForge" />
    <change item="Mereak_Battleaxe" property="DefaultRequiredMaterials[0].Count" value="4" />
    <change item="Mereak_Battleaxe" property="DefaultRequiredMaterials[1].Count" value="1" />
    <change item="Mereak_Battleaxe" property="DefaultRequiredMaterials[4].MaterialHandle.RowName" value="Item.MithrilIngot" />
    <change item="Mereak_Battleaxe" property="DefaultRequiredMaterials[4].Count" value="4" />
    <change item="Thrain_Warhammer" property="DefaultRequiredMaterials[0].MaterialHandle.RowName" value="Item.MithrilIngot" />
    <change item="Thrain_Warhammer" property="DefaultUnlocks.UnlockRequiredItems.UnlockRequiredItems.RowName" value="Item.MithrilIngot" />
    <change item="Restoration_Hammer_Tobi" property="DefaultRequiredMaterials[4].MaterialHandle.DataTable" value="0" />
    <change item="Restoration_Hammer_Tobi" property="DefaultRequiredMaterials[4].MaterialHandle.RowName" value="Item.Scrap" />
    <change item="Restoration_Hammer_Tobi" property="DefaultRequiredMaterials[4].Count" value="5" />
    <change item="Restoration_Hammer_Tobi" property="SandboxUnlocks.UnlockType" value="EMorRecipeUnlockType::Never" />
    <change item="Restoration_Hammer_Tobi" property="DefaultUnlocks.UnlockType" value="EMorRecipeUnlockType::Never" />
    <change item="Restoration_Hammer_Tobi" property="EnabledState" value="ERowEnabledState::Disabled" />
    <change item="CrimsonIngot" property="SandboxUnlocks.UnlockType" value="EMorRecipeUnlockType::Never" />
    <change item="CrimsonIngot" property="DefaultUnlocks.UnlockType" value="EMorRecipeUnlockType::Never" />
    <change item="CrimsonIngot" property="EnabledState" value="ERowEnabledState::Disabled" />
  </mod>
</definition>