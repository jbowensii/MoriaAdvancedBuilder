<?xml version='1.0' encoding='UTF-8'?>
<definition>
  <title>More Wardrobe Colors - DT_ItemTint (TintColor)</title>
  <author>GreenGorilla23</author>
  <description>A mod that adds more colors to the wardrobe</description>
  <mod file="Moria\Content\Items\Effects\DT_ItemTint.json">
    <!--  colors added

Cyan
Ruby
Magenta
Orange
Black
Reddish Brown
Azure - Cyan (Added)  -->
    <change item="Cyan" property="TintColor" value="">
      <add_property item="Cyan"><![CDATA[{
  "$type": "UAssetAPI.PropertyTypes.Structs.StructPropertyData, UAssetAPI",
  "StructType": "LinearColor",
  "SerializeNone": true,
  "StructGUID": "{00000000-0000-0000-0000-000000000000}",
  "SerializationControl": "NoExtension",
  "Operation": "None",
  "Name": "TintColor",
  "ArrayIndex": 0,
  "IsZero": false,
  "PropertyTagFlags": "None",
  "PropertyTagExtensions": "NoExtension",
  "Value": [
    {
      "$type": "UAssetAPI.PropertyTypes.Structs.LinearColorPropertyData, UAssetAPI",
      "Name": "TintColor",
      "ArrayIndex": 0,
      "IsZero": false,
      "PropertyTagFlags": "None",
      "PropertyTagExtensions": "NoExtension",
      "Value": {
        "$type": "UAssetAPI.UnrealTypes.FLinearColor, UAssetAPI",
        "R": "+0",
        "G": 0.75,
        "B": 0.75,
        "A": 1.0
      }
    }
  ]
}]]></add_property>
    </change>
    <!--  colors added

