<?xml version='1.0' encoding='UTF-8'?>
<definition>
  <title>More Wardrobe Colors - DT_ItemTint (Icon)</title>
  <author>GreenGorilla23</author>
  <description>A mod that adds more colors to the wardrobe</description>
  <mod file="Moria\Content\Items\Effects\DT_ItemTint.json">
    <!--  colors added

Cyan
Ruby
Magenta
Orange
Black
Reddish Brown
Azure - Cyan (Added)  -->
    <change item="Cyan" property="Icon" value="-1">
      <add_property item="Cyan"><![CDATA[{
  "$type": "UAssetAPI.PropertyTypes.Objects.ObjectPropertyData, UAssetAPI",
  "Name": "Icon",
  "ArrayIndex": 0,
  "IsZero": false,
  "PropertyTagFlags": "None",
  "PropertyTagExtensions": "NoExtension",
  "Value": -1
}]]></add_property>
    </change>
    <!--  colors added

Cyan
Ruby
Magenta
Orange
Black
Reddish Brown
Azure - Red (Added)  -->
