<?xml version='1.0' encoding='UTF-8'?>
<definition>
  <title>More Wardrobe Colors - DT_ItemTint (TintName)</title>
  <author>GreenGorilla23</author>
  <description>A mod that adds more colors to the wardrobe</description>
  <mod file="Moria\Content\Items\Effects\DT_ItemTint.json">
    <!--  colors added

Cyan
Ruby
Magenta
Orange
Black
Reddish Brown
Azure - Cyan (Added)  -->
    <change item="Cyan" property="TintName" value="Items.Ores.MoonStone.Name">
      <add_property item="Cyan"><![CDATA[{
  "$type": "UAssetAPI.PropertyTypes.Objects.TextPropertyData, UAssetAPI",
  "Flags": 0,
  "HistoryType": "StringTableEntry",
  "TableId": "/Game/Tech/Data/StringTables/Items.Items",
  "Namespace": null,
  "CultureInvariantString": null,
  "SourceFmt": null,
  "Arguments": null,
  "ArgumentsData": null,
  "TransformType": "ToLower",
  "SourceValue": null,
  "FormatOptions": null,
  "TargetCulture": null,
  "Name": "TintName",
  "ArrayIndex": 0,
  "IsZero": false,
  "PropertyTagFlags": "None",
  "PropertyTagExtensions": "NoExtension",
  "Value": "Items.Ores.MoonStone.Name"
}]]></add_property>
    </change>
